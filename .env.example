# -------------------------------
# 基础项目配置
# -------------------------------
TZ=Asia/Shanghai
PROJECT_NAME=goodsmall

# -------------------------------
# PostgreSQL
# -------------------------------
POSTGRES_DB=goodsmall
POSTGRES_USER=goodsmall
POSTGRES_PASSWORD=please_change_me

# backend 容器连接 postgres 的地址
DATABASE_URL=postgresql://goodsmall:please_change_me@postgres:5432/goodsmall

# -------------------------------
# Backend
# -------------------------------
BACKEND_PORT=8002
BACKEND_PUBLIC_URL=http://localhost:8002

ADMIN_USERNAME=admin
ADMIN_PASSWORD=please_change_admin_password
ADMIN_SESSION_SECRET=please_change_admin_session_secret
ADMIN_SESSION_DAYS=7

# 内部 API 鉴权（backend 与 bots 之间）
INTERNAL_API_TOKEN=please_change_internal_api_token

# -------------------------------
# USDT / TRON
# -------------------------------
USDT_TRON_API_BASE=https://api.trongrid.io
TRONGRID_API_KEY=
USDT_TRC20_CONTRACT=
USDT_POLL_SECONDS=20

PAYMENT_EXPIRE_MINUTES=30
PAYMENT_AMOUNT_OFFSET_ENABLED=true
PAYMENT_AMOUNT_OFFSET_STEP=0.001
PAYMENT_AMOUNT_OFFSET_SLOTS=20

# -------------------------------
# 物流
# -------------------------------
LOGISTICS_PROVIDER=kuaidi100
KUAIDI100_KEY=
KUAIDI100_CUSTOMER=
LOGISTICS_SYNC_SECONDS=1800

# -------------------------------
# Bot 运行参数
# -------------------------------
BOT_ENABLED_SYNC_SECONDS=5
BOT_RUNTIME_HEARTBEAT_SECONDS=15
SESSION_PUSH_SECONDS=5

# 自动同步 Bot 资料（可选）
BOT_PROFILE_AUTO_SYNC_ENABLED=false
BOT_PROFILE_AUTO_SYNC_SECONDS=3600
BOT_PROFILE_AUTO_SYNC_SCOPE=enabled
BOT_PROFILE_AUTO_SYNC_BOT_TYPE=all

# -------------------------------
# Telegram Bot Tokens
# -------------------------------
BUYER_BOT_TOKEN=
SESSION_BOT_TOKEN=
SHIPPING_BOT_TOKEN=
